{
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|png|gif|webp|svg|ico|avif|webm|mp4)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*).(js|css)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/listas-site/:path*",
      "destination": "/listas-site/:path*"
    },
    {
      "source": "/listas.html",
      "has": [
        { "type": "host", "value": "listas.tradingchango.com" }
      ],
      "destination": "/listas-site/index.html"
    },
    {
      "source": "/acerca-de",
      "has": [
        { "type": "host", "value": "listas.tradingchango.com" }
      ],
      "destination": "/listas-site/acerca-de.html"
    },
    {
      "source": "/contacto",
      "has": [
        { "type": "host", "value": "listas.tradingchango.com" }
      ],
      "destination": "/listas-site/contacto.html"
    },
    {
      "source": "/terminos",
      "has": [
        { "type": "host", "value": "listas.tradingchango.com" }
      ],
      "destination": "/listas-site/terminos.html"
    },
    {
      "source": "/listas",
      "destination": "/listas.html"
    },
    {
      "source": "/listas-sitemap.xml",
      "destination": "/listas-sitemap.xml"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "listas.tradingchango.com" }
      ],
      "destination": "/listas-site/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "trailingSlash": false
}
