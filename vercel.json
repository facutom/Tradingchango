{
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|png|gif|webp|svg|ico|avif|webm|mp4)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*).(js|css)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "listas.tradingchango.com"
        }
      ],
      "destination": "/listas.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "tradingchango.com"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/listas",
      "destination": "/listas.html"
    },
    {
      "source": "/((?!listas|listas.html|api|assets|sitemap.xml|sw.js).*)",
      "has": [
        {
          "type": "host",
          "value": "tradingchango.com"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/((?!listas|listas.html|api|assets|sitemap.xml|sw.js).*)",
      "has": [
        {
          "type": "host",
          "value": "listas.tradingchango.com"
        }
      ],
      "destination": "/listas.html"
    }
  ],
  "trailingSlash": false
}
